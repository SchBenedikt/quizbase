
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user (presenter) of Quizbase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "Survey": {
      "title": "Survey",
      "description": "A collection of questions created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "isPublic": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "description": "A single interactive question within a survey.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pollId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["multiple-choice", "open-text", "rating", "slider", "word-cloud", "ranking", "scale", "guess-number"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["id", "pollId", "text", "type", "order"]
    },
    "Session": {
      "title": "Session",
      "description": "A live interactive instance of a survey.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pollId": { "type": "string" },
        "userId": { "type": "string" },
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "theme": { "type": "string" },
        "currentQuestionId": { "type": "string" },
        "showResultsToParticipants": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "pollId", "userId", "code", "status", "createdAt"]
    },
    "Participant": {
      "title": "Participant",
      "description": "An individual attending a live session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nickname": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "kicked"] },
        "score": { "type": "number", "default": 0 },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "status", "joinedAt"]
    },
    "Response": {
      "title": "Response",
      "description": "A participant response to a question.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "questionId": { "type": "string" },
        "value": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sessionId", "questionId", "value", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profile data."
    },
    "/users/{userId}/surveys/{surveyId}": {
      "schema": "#/entities/Survey",
      "description": "Surveys created by a user."
    },
    "/users/{userId}/surveys/{surveyId}/questions/{questionId}": {
      "schema": "#/entities/Question",
      "description": "Questions within a specific survey."
    },
    "/sessions/{sessionId}": {
      "schema": "#/entities/Session",
      "description": "Live sessions."
    },
    "/sessions/{sessionId}/participants/{userId}": {
      "schema": "#/entities/Participant",
      "description": "Participants in a session."
    },
    "/sessions/{sessionId}/responses/{responseId}": {
      "schema": "#/entities/Response",
      "description": "Responses submitted during a session."
    }
  }
}
