rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PopPulse* Security Rules
     * 
     * Presenters own their profiles and surveys.
     * Participants can join sessions and submit responses.
     * Session owners can see all responses in their sessions.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('id');
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/surveys/{surveyId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('userId');
      allow delete: if isExistingOwner(userId);

      match /questions/{questionId} {
        // Participants need to be able to get the question details to participate
        allow get: if true;
        allow list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /sessions/{sessionId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && isUnchanged('userId');
      allow delete: if isExistingOwner(resource.data.userId);

      match /responses/{responseId} {
        // Allow the session creator to list all responses
        allow list: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow get: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        
        // Participants can submit if active
        allow create: if get(/databases/$(database)/documents/sessions/$(sessionId)).data.status == 'active';
        allow update, delete: if false;
      }
    }
  }
}
