
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // Support Global Discovery (Collection Group) — public surveys readable by anyone
    // This rule must come first to avoid conflicts with more specific rules
    match /{path=**}/surveys/{surveyId} {
      allow read: if resource.data.isPublic == true;
    }
    
    // Additional rule for collection group queries
    match /surveys/{surveyId} {
      allow read: if resource.data.isPublic == true;
    }

    // Categories - system-wide public categories
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.isPublic == true;
      allow update, delete: if false; // Public categories are managed by system
    }

    // User-specific categories
    match /users/{userId}/categories/{categoryId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    // User profiles — owners can manage, anyone can read for public profile pages
    match /users/{userId} {
      allow get: if true; // Public: needed for /profile/[userId] page to show name, username, bio
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/surveys/{surveyId} {
      allow get: if isOwner(userId) || resource.data.isPublic == true;
      allow list: if isOwner(userId) || resource.data.isPublic == true;
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && isUnchanged('userId');
      allow delete: if isOwner(userId);

      match /questions/{questionId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    match /sessions/{sessionId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /participants/{participantId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.auth.uid == participantId;
        allow update: if isSignedIn() && (
          request.auth.uid == participantId ||
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid
        );
        allow delete: if false;
      }

      match /responses/{responseId} {
        allow read: if true;     // Results are visible to all — results page relies on this
        allow create: if true;   // Anonymous and logged-in participants can submit answers
        allow update, delete: if false;
      }

      match /reactions/{reactionId} {
        allow read: if true;     // Presenter subscribes to reactions feed
        allow create: if isSignedIn(); // Authenticated (incl. anonymous) users can react
        allow update, delete: if false;
      }
    }
  }
}

