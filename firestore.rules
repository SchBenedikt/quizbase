
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('id');
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/surveys/{surveyId} {
      allow get: if isOwner(userId) || resource.data.isPublic == true;
      allow list: if isOwner(userId) || resource.data.isPublic == true;
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('userId');
      allow delete: if isExistingOwner(userId);

      match /questions/{questionId} {
        allow get: if true;
        allow list: if true;
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /sessions/{sessionId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && isUnchanged('userId');
      allow delete: if isExistingOwner(resource.data.userId);

      match /participants/{userId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if (isSignedIn() && request.auth.uid == userId) || isOwner(get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId);
      }

      match /responses/{responseId} {
        allow list, get: if (get(/databases/$(database)/documents/sessions/$(sessionId)).data.showResultsToParticipants == true) ||
                         (isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid);
        
        allow create: if get(/databases/$(database)/documents/sessions/$(sessionId)).data.status == 'active';
        allow update, delete: if false;
      }
    }
    
    // Support Global Discovery (Collection Group)
    match /{path=**}/surveys/{surveyId} {
      allow read: if resource.data.isPublic == true;
    }
  }
}
